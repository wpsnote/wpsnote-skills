#!/usr/bin/env python3
# cal-move — 修改日历事件的时间（通过 UID）
#
# 用法：
#   cal-move <UID> <新开始时间> [新结束时间]
#   cal-move <UID> tomorrow
#   cal-move <UID> tomorrow 20:00

import sys
import os
import subprocess
import tempfile
from datetime import datetime, timedelta

def usage():
    print("""用法: cal-move <UID> <新时间> [新结束时间]

新时间格式:
  "YYYY-MM-DD HH:MM"   精确时间
  "YYYY-MM-DD"         全天（移到该天）
  tomorrow             明天（同一时间）
  tomorrow HH:MM       明天指定时间（如 tomorrow 20:00）
  +N                   N 天后（同一时间）

示例:
  cal-move abc123 "2026-03-25 15:00"
  cal-move abc123 "2026-03-25 15:00" "2026-03-25 16:00"
  cal-move abc123 tomorrow
  cal-move abc123 tomorrow 20:00
  cal-move abc123 +1""")
    sys.exit(1)

if len(sys.argv) < 3:
    usage()

EVENT_UID = sys.argv[1]
raw1 = sys.argv[2]
raw2 = sys.argv[3] if len(sys.argv) > 3 else ""

# ── 解析新时间 ─────────────────────────────────────────────────────────────────
today = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0)
now   = datetime.now()
ref   = datetime(2001, 1, 1)

def to_as(dt):
    return int((dt - ref).total_seconds())

keep_duration = False
new_start = None
new_end   = None

if raw1 == "tomorrow":
    new_start = today + timedelta(days=1)
    keep_duration = True
    if raw2 and ":" in raw2 and len(raw2) <= 5:
        h, m = map(int, raw2.split(":"))
        new_start = new_start.replace(hour=h, minute=m, second=0)
        raw2 = ""  # already consumed
elif raw1.startswith("+") and raw1[1:].isdigit():
    new_start = today + timedelta(days=int(raw1[1:]))
    keep_duration = True
elif len(raw1) == 10 and raw1[4] == "-":
    new_start = datetime.strptime(raw1, "%Y-%m-%d")
    keep_duration = not raw2
elif len(raw1) >= 16:
    new_start = datetime.strptime(raw1[:16], "%Y-%m-%d %H:%M")
    keep_duration = not raw2
else:
    print(f"ERROR: 无法解析时间 {raw1!r}", file=sys.stderr)
    usage()

if raw2 and not keep_duration:
    try:
        new_end = datetime.strptime(raw2[:16], "%Y-%m-%d %H:%M")
    except ValueError:
        new_end = datetime.strptime(raw2, "%Y-%m-%d").replace(hour=23, minute=59, second=59)

AS_NEW_START = to_as(new_start)
AS_NEW_END   = to_as(new_end) if new_end else 0
KEEP_DUR     = 1 if keep_duration else 0

# ── 从缓存读取 UID 对应日历，减少全量扫描 ───────────────────────────────────────
cache_file = os.path.expanduser("~/.cursor/skills/mac-calendar/.cache/events.tsv")
hint_cal = ""
if os.path.exists(cache_file):
    try:
        with open(cache_file, "r", encoding="utf-8") as f:
            for line in f:
                parts = line.rstrip("\n").split("\t")
                if len(parts) >= 2 and parts[0] == EVENT_UID:
                    hint_cal = parts[1]
    except Exception:
        pass

script = f'''
tell application "Calendar"
    set refDate to (current date)
    set year of refDate to 2001
    set month of refDate to 1
    set day of refDate to 1
    set time of refDate to 0

    set newStart to refDate + {AS_NEW_START}
    set keepDur  to ({KEEP_DUR} = 1)
    set targetUID to "{EVENT_UID}"
    set hintCal to "{hint_cal}"
    set found to false

    -- 先在提示日历查（最快）
    if hintCal is not "" then
        try
            tell calendar hintCal
                set evs to (every event whose uid is targetUID)
                if (count of evs) > 0 then
                    set e to item 1 of evs
                    set found to true
                    set origStart to start date of e
                    set origEnd   to end date of e
                    if keepDur then
                        set dur to origEnd - origStart
                        set newEnd to newStart + dur
                        if newStart > origStart then
                            set end date of e to newEnd
                            set start date of e to newStart
                        else
                            set start date of e to newStart
                            set end date of e to newEnd
                        end if
                    else
                        set newEnd to refDate + {AS_NEW_END}
                        if newStart > origStart then
                            set end date of e to newEnd
                            set start date of e to newStart
                        else
                            set start date of e to newStart
                            set end date of e to newEnd
                        end if
                    end if
                    return "OK: " & summary of e
                end if
            end tell
        end try
    end if

    -- 再全日历兜底
    repeat with c in calendars
        try
            set evs to (every event of c whose uid is targetUID)
            if (count of evs) > 0 then
                set e to item 1 of evs
                set found to true
                set origStart to start date of e
                set origEnd   to end date of e
                if keepDur then
                    set dur to origEnd - origStart
                    set newEnd to newStart + dur
                    if newStart > origStart then
                        set end date of e to newEnd
                        set start date of e to newStart
                    else
                        set start date of e to newStart
                        set end date of e to newEnd
                    end if
                else
                    set newEnd to refDate + {AS_NEW_END}
                    if newStart > origStart then
                        set end date of e to newEnd
                        set start date of e to newStart
                    else
                        set start date of e to newStart
                        set end date of e to newEnd
                    end if
                end if
                return "OK: " & summary of e
            end if
        end try
    end repeat

    if not found then return "ERROR: 找不到 UID=" & targetUID
end tell
'''

with tempfile.NamedTemporaryFile(mode="w", suffix=".applescript",
                                  encoding="utf-8", delete=False) as f:
    f.write(script)
    tmp = f.name

try:
    r = subprocess.run(["osascript", tmp], capture_output=True,
                       text=True, timeout=180, encoding="utf-8")
    result = (r.stdout + r.stderr).strip()
finally:
    os.unlink(tmp)

if r.returncode != 0:
    print((result or f"ERROR: osascript 失败，exit={r.returncode}"), file=sys.stderr)
    sys.exit(1)

if not result:
    print("ERROR: osascript 返回空结果", file=sys.stderr)
    sys.exit(1)

if result.startswith("ERROR"):
    print(result, file=sys.stderr)
    sys.exit(1)

print(f"✓ 事件已移动：{result}")
