{
  "id": "web-importer-golden-import-article-with-media",
  "suite": "golden",
  "skill": "web-importer",
  "prompt": "我想把这篇文章留档，后面开会要引用。请把这个链接导入 WPS 笔记，标题保持原文，正文层次和配图尽量保留：https://fixture.local/run-web-001",
  "seed": {
    "description": "Codex 侧通过 MCP 预置一个可抓取的文章 fixture 页面，以及一篇无关控制笔记。",
    "entities": [
      "fixture.run-web-001",
      "notes.control_note"
    ],
    "state_fixtures": {
      "original": "evals/fixtures/web-importer/import-article-with-media.original.json",
      "final": "evals/fixtures/web-importer/import-article-with-media.final.json"
    }
  },
  "original_state_collectors": [
    {
      "id": "imported_article",
      "kind": "search_note_by_title",
      "title": "如何把周报整理成知识卡片"
    },
    {
      "id": "title_match_count",
      "kind": "search_note_by_title_count",
      "path": "stats.imported_article_title_match_count",
      "title": "如何把周报整理成知识卡片"
    },
    {
      "id": "control_note",
      "kind": "note_snapshot",
      "path": "notes.control_note"
    }
  ],
  "expected_state": {
    "entities_expected_created": [
      "notes.imported_article"
    ],
    "entities_expected_updated": [],
    "entities_expected_unchanged": [
      "notes.control_note"
    ],
    "required_changes": [
      {
        "kind": "value_equals",
        "path": "notes.imported_article.title",
        "value": "如何把周报整理成知识卡片",
        "message": "导入后的标题必须与网页标题一致"
      },
      {
        "kind": "value_equals",
        "path": "notes.imported_article.source_url",
        "value": "https://fixture.local/run-web-001",
        "message": "导入后的笔记必须保留原网页链接"
      },
      {
        "kind": "count_at_least",
        "path": "notes.imported_article.heading_count",
        "value": 2,
        "message": "基础标题层级应被保留"
      },
      {
        "kind": "value_contains_all",
        "path": "notes.imported_article.key_paragraphs",
        "values": [
          "背景介绍",
          "结论摘要"
        ],
        "message": "网页关键段落必须导入"
      },
      {
        "kind": "count_at_least",
        "path": "notes.imported_article.image_count",
        "value": 1,
        "message": "至少应导入一张图片"
      },
      {
        "kind": "value_equals",
        "path": "stats.imported_article_title_match_count",
        "value": 1,
        "message": "同标题笔记应只有一篇，避免重复创建"
      }
    ],
    "forbidden_changes": [
      {
        "kind": "path_changed",
        "path": "notes.control_note",
        "message": "网页导入不能污染控制笔记"
      }
    ],
    "tolerance_rules": [
      {
        "kind": "ignore_paths",
        "paths": [
          "notes.imported_article.metadata.fetch_time"
        ],
        "label": "允许抓取时间不同"
      }
    ]
  },
  "final_state_collectors": [
    {
      "id": "imported_article",
      "kind": "note_snapshot",
      "path": "notes.imported_article"
    },
    {
      "id": "title_match_count",
      "kind": "search_note_by_title_count",
      "path": "stats.imported_article_title_match_count",
      "title": "如何把周报整理成知识卡片"
    },
    {
      "id": "control_note",
      "kind": "note_snapshot",
      "path": "notes.control_note"
    }
  ],
  "grader": {
    "mode": "outcome-only",
    "report": "state_diff_report",
    "max_diff_entries": 25
  },
  "cleanup": {
    "description": "删除本次网页导入结果和 run-web-001 相关测试对象。"
  }
}
