    "required_changes": [
      {
        "kind": "set_equals",
        "path": "notes.followup_note.tags",
        "value": [
          "#待办",
          "#工作/客户/华东组",
          "#项目/Alpha/合同"
        ],
        "message": "合同跟进笔记的标签集合必须收敛到统一写法"
      },
      {
        "kind": "set_equals",
        "path": "notes.weekly_note.tags",
        "value": [
          "#待办",
          "#会议/周会",
          "#项目/Alpha/联调"
        ],
        "message": "例会散记必须迁移到统一提醒标签"
      },
      {
        "kind": "set_equals",
        "path": "notes.qa_note.tags",
        "value": [
          "#待办",
          "#项目/Alpha/验收"
        ],
        "message": "已经混用两种写法的验收笔记必须去重并统一"
