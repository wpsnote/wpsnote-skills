{
  "id": "tag-organize-golden-merge-synonym-tags",
  "suite": "golden",
  "skill": "tag-organize",
  "prompt": "我刚把这周东一条西一条的笔记翻了一遍，同一种提醒标签被我写成了好几种，你帮我顺一下；纯归档说明那类先别动。",
  "seed": {
    "description": "通过 MCP 预置 5 篇使用 todo/to-do/待办 混写的真实脏笔记、1 篇已规范的个人便签和 1 篇纯归档对照笔记；标签同时覆盖层级标签与简单标签。",
    "entities": [
      "notes.followup_note",
      "notes.weekly_note",
      "notes.qa_note",
      "notes.vendor_note",
      "notes.admin_note",
      "notes.personal_tasks_note",
      "notes.control_note",
      "tags.todo",
      "tags.to-do",
      "tags.待办",
      "tags.工作/客户/华东组",
      "tags.项目/Alpha/合同",
      "tags.会议/周会",
      "tags.项目/Alpha/联调",
      "tags.项目/Alpha/验收",
      "tags.采购",
      "tags.供应商/A类",
      "tags.报销",
      "tags.存档/财务"
