{
  "id": "tag-organize-golden-merge-synonym-tags",
  "suite": "golden",
  "skill": "tag-organize",
  "prompt": "我最近这几篇工作笔记的待办标签写法有点乱，有的写 `#todo`，有的写 `#to-do`，也有一篇已经写成了 `#待办`。你先给我一个很简短的整理方案；如果只是小改动，就直接处理。先只看这三篇：`Alpha 项目合同跟进`、`周会待处理`、`个人任务清单`。保留像 `#工作` 这种已经合理的标签，别改坏正文，也不要动 `发票归档说明` 这篇。",
  "seed": {
    "description": "通过 MCP 预置三篇真实感较强的工作笔记：两篇待办标签写法不一致，一篇已使用中文待办标签；另放一篇归档说明作为无关对照笔记。",
    "entities": [
      "notes.followup_note",
      "notes.weekly_note",
      "notes.personal_tasks_note",
      "notes.control_note",
      "tags.todo",
      "tags.to-do",
      "tags.待办"
    ]
  },
  "original_state_collectors": [
    {
      "id": "followup_note",
      "kind": "note_snapshot",
      "path": "notes.followup_note"
    },
    {
      "id": "weekly_note",
      "kind": "note_snapshot",
      "path": "notes.weekly_note"
    },
    {
      "id": "personal_tasks_note",
      "kind": "note_snapshot",
      "path": "notes.personal_tasks_note"
    },
    {
      "id": "control_note",
      "kind": "note_snapshot",
      "path": "notes.control_note"
    },
    {
      "id": "tags",
      "kind": "tag_tree",
      "path": "tags"
    }
  ],
  "expected_state": {
    "entities_expected_created": [],
    "entities_expected_updated": [
      "notes.followup_note",
      "notes.weekly_note"
    ],
    "entities_expected_unchanged": [
      "notes.personal_tasks_note",
      "notes.control_note"
    ],
    "required_changes": [
      {
        "kind": "set_equals",
        "path": "notes.followup_note.tags",
        "value": [
          "#待办",
          "#工作"
        ],
        "message": "项目跟进笔记的标签集合必须收敛到统一写法"
      },
      {
        "kind": "set_equals",
        "path": "notes.weekly_note.tags",
        "value": [
          "#待办"
        ],
        "message": "周会记录笔记必须迁移到统一待办标签"
      },
      {
        "kind": "set_equals",
        "path": "notes.personal_tasks_note.tags",
        "value": [
          "#待办"
        ],
        "message": "原本已使用中文待办标签的笔记应保持不变"
      },
      {
        "kind": "path_missing",
        "path": "tags.todo",
        "message": "旧标签 todo 应被清理出最终标签树"
      },
      {
        "kind": "path_missing",
        "path": "tags.to-do",
        "message": "旧标签 to-do 应被清理出最终标签树"
      }
    ],
    "forbidden_changes": [
      {
        "kind": "path_changed",
        "path": "notes.control_note",
        "message": "无关控制笔记不能被改动"
      }
    ],
    "tolerance_rules": [
      {
        "kind": "ignore_paths",
        "paths": [
          "tags.待办.note_count"
        ],
        "label": "允许标签引用数在同步后波动"
      }
    ]
  },
  "final_state_collectors": [
    {
      "id": "followup_note",
      "kind": "note_snapshot",
      "path": "notes.followup_note"
    },
    {
      "id": "weekly_note",
      "kind": "note_snapshot",
      "path": "notes.weekly_note"
    },
    {
      "id": "personal_tasks_note",
      "kind": "note_snapshot",
      "path": "notes.personal_tasks_note"
    },
    {
      "id": "control_note",
      "kind": "note_snapshot",
      "path": "notes.control_note"
    },
    {
      "id": "tags",
      "kind": "tag_tree",
      "path": "tags"
    }
  ],
  "grader": {
    "mode": "outcome-only",
    "report": "state_diff_report",
    "max_diff_entries": 25
  },
  "cleanup": {
    "description": "删除本次样张写入的四篇测试笔记，并回收 todo / to-do 这组临时测试标签。"
  }
}
