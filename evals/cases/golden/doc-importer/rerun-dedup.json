{
  "id": "doc-importer-golden-rerun-dedup",
  "suite": "golden",
  "skill": "doc-importer",
  "prompt": "昨天那份产品周报我应该已经导过一次了。你再处理一下这份同名文档；如果已经有完整笔记，就不要重复创建，也不要改动现有那篇内容。",
  "seed": {
    "description": "通过 MCP 预先创建一篇已导入的目标笔记和一份重复的导入输入，再执行重复导入。",
    "entities": [
      "notes.import_target",
      "notes.control_note"
    ]
  },
  "original_state_collectors": [
    {
      "id": "import_target",
      "kind": "note_snapshot",
      "path": "notes.import_target"
    },
    {
      "id": "control_note",
      "kind": "note_snapshot",
      "path": "notes.control_note"
    },
    {
      "id": "stats",
      "kind": "title_match_count",
      "path": "stats"
    }
  ],
  "expected_state": {
    "entities_expected_created": [],
    "entities_expected_updated": [],
    "entities_expected_unchanged": [
      "notes.import_target",
      "notes.control_note"
    ],
    "required_changes": [
      {
        "kind": "path_exists",
        "path": "notes.import_target",
        "message": "原有导入笔记必须仍然存在"
      },
      {
        "kind": "value_equals",
        "path": "notes.import_target.title",
        "value": "产品周报｜4月第4周（run-002）",
        "message": "重复导入后目标笔记标题必须保持不变"
      },
      {
        "kind": "path_missing",
        "path": "notes.import_target_duplicate",
        "message": "重复导入不能产生额外重复笔记"
      },
      {
        "kind": "count_equals",
        "path": "stats.import_target_note_count",
        "value": 1,
        "message": "目标标题的匹配笔记数量必须仍为 1"
      }
    ],
    "forbidden_changes": [
      {
        "kind": "path_changed",
        "path": "notes.import_target",
        "message": "用户明确要求已有就别再建时，原目标笔记不应被无端改写"
      },
      {
        "kind": "path_changed",
        "path": "notes.control_note",
        "message": "重复导入不能污染无关控制笔记"
      }
    ],
    "tolerance_rules": [
      {
        "kind": "ignore_paths",
        "paths": [
          "stats.collection_time"
        ],
        "label": "忽略采样时间"
      }
    ]
  },
  "final_state_collectors": [
    {
      "id": "import_target",
      "kind": "note_snapshot",
      "path": "notes.import_target"
    },
    {
      "id": "control_note",
      "kind": "note_snapshot",
      "path": "notes.control_note"
    },
    {
      "id": "stats",
      "kind": "title_match_count",
      "path": "stats"
    }
  ],
  "grader": {
    "mode": "outcome-only",
    "report": "state_diff_report",
    "max_diff_entries": 20
  },
  "cleanup": {
    "description": "删除 run-002 相关的测试笔记。"
  }
}
