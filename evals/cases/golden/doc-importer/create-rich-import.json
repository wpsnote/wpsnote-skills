{
  "id": "doc-importer-golden-create-rich-import",
  "suite": "golden",
  "skill": "doc-importer",
  "prompt": "我刚上传了一份产品周报，帮我导成一篇 WPS 笔记，标题就叫「产品周报｜4月第3周（run-001）」。开头保留一下来源说明，正文里至少保留“本周重点”和“风险与阻塞”两节，两张配图也一起放进去。",
  "seed": {
    "description": "通过 MCP 在远端准备一份可导入的用户周报输入，并保留一篇无关对照笔记用于污染检测。",
    "entities": [
      "fixture.run-001-report",
      "notes.control_note"
    ]
  },
  "original_state_collectors": [
    {
      "id": "import_target",
      "kind": "search_note_by_title",
      "title": "产品周报｜4月第3周（run-001）"
    },
    {
      "id": "control_note",
      "kind": "note_snapshot",
      "path": "notes.control_note"
    },
    {
      "id": "stats",
      "kind": "title_match_count",
      "path": "stats"
    }
  ],
  "expected_state": {
    "entities_expected_created": [
      "notes.import_target"
    ],
    "entities_expected_updated": [],
    "entities_expected_unchanged": [
      "notes.control_note"
    ],
    "required_changes": [
      {
        "kind": "path_exists",
        "path": "notes.import_target",
        "message": "必须创建导入后的目标笔记"
      },
      {
        "kind": "value_equals",
        "path": "notes.import_target.title",
        "value": "产品周报｜4月第3周（run-001）",
        "message": "导入后的标题必须正确"
      },
      {
        "kind": "value_contains",
        "path": "notes.import_target.body_xml",
        "value": "来源",
        "message": "导入后的正文必须保留来源说明"
      },
      {
        "kind": "value_contains_all",
        "path": "notes.import_target.key_paragraphs",
        "values": [
          "本周重点：会员增长恢复到周环比 12%",
          "风险与阻塞：安卓端还有 2 个高优缺陷未关闭"
        ],
        "message": "关键段落必须完整落库"
      },
      {
        "kind": "count_equals",
        "path": "notes.import_target.image_count",
        "value": 2,
        "message": "图片数量必须与 fixture 一致"
      },
      {
        "kind": "count_equals",
        "path": "stats.import_target_note_count",
        "value": 1,
        "message": "导入后目标标题的笔记数量必须为 1"
      }
    ],
    "forbidden_changes": [
      {
        "kind": "path_changed",
        "path": "notes.control_note",
        "message": "无关控制笔记不能被污染"
      }
    ],
    "tolerance_rules": [
      {
        "kind": "ignore_paths",
        "paths": [
          "notes.import_target.metadata.updated_at",
          "stats.collection_time"
        ],
        "label": "忽略采样时间与更新时间"
      }
    ]
  },
  "final_state_collectors": [
    {
      "id": "import_target",
      "kind": "note_snapshot",
      "path": "notes.import_target"
    },
    {
      "id": "control_note",
      "kind": "note_snapshot",
      "path": "notes.control_note"
    },
    {
      "id": "stats",
      "kind": "title_match_count",
      "path": "stats"
    }
  ],
  "grader": {
    "mode": "outcome-only",
    "report": "state_diff_report",
    "max_diff_entries": 25
  },
  "cleanup": {
    "description": "删除 run-001 相关的测试笔记。"
  }
}
